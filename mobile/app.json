{
  "expo": {
    "name": "IDEAL",
    "slug": "ideal-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ideal.personalos",
      "infoPlist": {
        "NSCameraUsageDescription": "IDEAL uses the camera for profile photos.",
        "NSLocationWhenInUseUsageDescription": "IDEAL uses your location to geo-tag skill practice sessions.",
        "NSUserNotificationsUsageDescription": "IDEAL sends habit reminders and daily iteration prompts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E9E4F0",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.ideal.personalos",
      "permissions": [
        "NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
